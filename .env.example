# Google Gemini API key (required for AI responses)
# Get one at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model (free tier: gemini-2.0-flash)
# Avoid gemini-2.0-flash-lite — it has no free-tier quota (limit: 0)
# VITE_GEMINI_MODEL=gemini-2.0-flash

# NASA API key (required for Astronomy Picture of the Day)
# Get a free key at: https://api.nasa.gov/ — or omit to use the public DEMO_KEY (rate-limited)
VITE_NASA_API_KEY=your_nasa_api_key_here
